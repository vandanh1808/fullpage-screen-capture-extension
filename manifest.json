{
  "manifest_version": 3,
  "name": "Fullpage Screen Capture",
  "description": "Auto scroll and capture full page screenshots, saved as ZIP",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "downloads", "debugger"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
